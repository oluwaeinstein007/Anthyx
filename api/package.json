{
  "name": "@anthyx/api",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts src/workers/index.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist --out-extension:.js=.js --external:*.node",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@anthyx/config": "workspace:*",
    "@anthyx/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.600.0",
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.0.0",
    "https-proxy-agent": "^7.0.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "social-mcp": "^1.8.1",
    "openai": "^4.47.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.0",
    "stripe": "^15.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.20.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
