TELEGRAM_BOT_TOKEN=

# ── Image Generation ──────────────────────────────────────────────────
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# ── Template Asset Generation ─────────────────────────────────────────
BANNERBEAR_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── IP Rotation / Proxy ───────────────────────────────────────────────
BRIGHT_DATA_PROXY_1=http://user:pass@zproxy.lum-superproxy.io:22225
BRIGHT_DATA_PROXY_2=http://user:pass@zproxy.lum-superproxy.io:22226
BRIGHT_DATA_PROXY_3=http://user:pass@zproxy.lum-superproxy.io:22227

# ── Storage (CDN / Assets) ────────────────────────────────────────────
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=anthyx-assets
# OR DigitalOcean Spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=anthyx-assets

# ── Security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=minimum_32_char_random_string_change_me
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=64_char_hex_string_change_me
OAUTH_STATE_SECRET=change_me

# ── Billing (Stripe) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_STARTER_ANNUAL=price_
STRIPE_PRICE_GROWTH_MONTHLY=price_
STRIPE_PRICE_GROWTH_ANNUAL=price_
STRIPE_PRICE_AGENCY_MONTHLY=price_
STRIPE_PRICE_AGENCY_ANNUAL=price_
STRIPE_PRICE_SCALE_MONTHLY=price_
STRIPE_PRICE_SCALE_ANNUAL=price_

# ── Email ─────────────────────────────────────────────────────────────
# Resend (recommended) or SendGrid
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@anthyx.ai

# ── Monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Next.js (dashboard only) ──────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_minimum_32_chars
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
